{
  "name": "default",
  "version": "1.0.0",
  "description": "DoD por defecto para tareas estandar sin riesgo alto",
  "required_evidence": ["pre-merge-review"],
  "acceptance_criteria_base": [
    "Codigo implementado segun work-order",
    "Sin archivos en forbidden_files modificados",
    "Tests pasan",
    "Sin findings P0 abiertos"
  ],
  "rollback_plan_required": false,
  "default_allowed_files": ["**/*"],
  "default_forbidden_files": [
    ".env", ".env.*", "**/secrets/**", "*.pem", "*.key"
  ],
  "max_files_changed_default": 8,
  "max_net_new_lines_default": 500
}
