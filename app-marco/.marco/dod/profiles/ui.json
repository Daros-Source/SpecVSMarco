{
  "name": "ui",
  "version": "1.1.0",
  "description": "DoD para cambios de UI/UX. v1.1: agrega referencia a PATTERNS.md como guia opt-in.",
  "required_evidence": ["ui-review", "pre-merge-review"],
  "acceptance_criteria_base": [
    "Componente implementado segun spec del work-order",
    "Cumple REGLAS de policies/presets/vozdigital/design-system/DESIGN_SYSTEM.md",
    "Estados de UI bien resueltos: loading, error, empty, success",
    "Accesibilidad basica verificada (labels, contraste, navegacion teclado)",
    "Responsive en mobile y desktop",
    "i18n: strings visibles usan t('namespace.key')",
    "Tests de componente pasan",
    "Sin findings P0 abiertos"
  ],
  "rollback_plan_required": false,
  "default_allowed_files": ["src/components/**", "src/pages/**", "src/styles/**", "tests/**"],
  "default_forbidden_files": [
    ".env", ".env.*", "**/secrets/**", "*.pem", "*.key",
    "src/auth/**", "src/payments/**"
  ],
  "recommended_references": [
    "policies/presets/vozdigital/design-system/DESIGN_SYSTEM.md",
    "policies/presets/vozdigital/design-system/PATTERNS.md",
    "design-system/templates/react/",
    "design-system/catalog.json"
  ],
  "max_files_changed_default": 10,
  "max_net_new_lines_default": 600
}
